# Caddy v2 — TLS termination + reverse proxy for Kawalec Command Center.
# Let's Encrypt obtained automatically based on the hostname below.
# Override the hostname per environment via the CADDY_HOST env var
# (passed through docker-compose.prod.yml) if needed.

{
	# Operator email for Let's Encrypt notifications.
	email {$ADMIN_EMAIL}

	# Tweak as needed — staging during initial DNS rollout to avoid LE rate limits.
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

cc.kawalec.pl {
	encode zstd gzip

	# Standard security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Reverse proxy to Next.js app inside the docker network.
	reverse_proxy app:3000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		header_up Host {host}
	}

	log {
		output stdout
		format console
	}
}
