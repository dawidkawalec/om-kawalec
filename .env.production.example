# Kawalec Command Center — production env template.
# Copy to .env on the VPS, fill in secrets, never commit.
# Generate secure secrets:
#   openssl rand -base64 48 | tr -d '\n'    # JWT_SECRET / AUTH_SECRET / encryption key
#   openssl rand -hex 32                    # MEILISEARCH master key
#   pwgen -s 32 1                           # POSTGRES_PASSWORD / superadmin password

# --- Application URL & operator ---
APP_URL=https://cc.kawalec.pl
ADMIN_EMAIL=info@craftweb.pl
DEPLOY_ENV=production

# --- Postgres (private inside docker network) ---
POSTGRES_USER=command_center
POSTGRES_PASSWORD=CHANGE-ME-strong-postgres-password
POSTGRES_DB=command_center

# --- Secrets (rotate yearly) ---
JWT_SECRET=CHANGE-ME-48-byte-base64-string
AUTH_SECRET=CHANGE-ME-48-byte-base64-string
TENANT_DATA_ENCRYPTION_KEY=CHANGE-ME-32-plus-chars-encryption-key

# --- Meilisearch ---
MEILISEARCH_MASTER_KEY=CHANGE-ME-hex-32
MEILISEARCH_API_KEY=CHANGE-ME-hex-32

# --- AI provider (Google Gemini per PRD D2) ---
OM_AI_PROVIDER=google
OM_AI_MODEL=google/gemini-2.5-flash
GOOGLE_GENERATIVE_AI_API_KEY=
# Anthropic as secondary fallback (optional):
ANTHROPIC_API_KEY=

# --- Initial superadmin (created on first init) ---
OM_INIT_SUPERADMIN_EMAIL=info@craftweb.pl
OM_INIT_SUPERADMIN_PASSWORD=CHANGE-ME-strong-startup-password

# --- Email (optional, for notifications/onboarding) ---
EMAIL_FROM=no-reply@kawalec.pl
NOTIFICATIONS_EMAIL_FROM=no-reply@kawalec.pl
RESEND_API_KEY=

# --- Twenty CRM source (for the kawalec import-twenty CLI) ---
# Used only when running `mercato kawalec import-twenty`. Optional otherwise.
# Inside the VPS this resolves to the twenty-db-1 container hostname once
# cc-app is connected to the twenty_default docker network:
#   docker network connect twenty_default cc-app
# TWENTY_DATABASE_URL=postgres://postgres:<twenty-db-password>@twenty-db-1:5432/default

# --- MCP server (Phase 1 D3: mutation approval ON) ---
# Enable once initial deploy is verified.
# OM_MCP_ENABLED=true
# OM_MCP_AUTH_TOKEN=CHANGE-ME-long-random-token
